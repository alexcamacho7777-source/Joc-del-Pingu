<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="vista.PantallaJuego"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #080e1a;">

    <!-- MENÚ SUPERIOR -->
    <top>
        <MenuBar style="-fx-background-color: #0c1a32; -fx-border-color: #1a3a5c; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Joc">
                    <items>
                        <MenuItem fx:id="newGame"  text="Nova Partida"     onAction="#handleNewGame"/>
                        <MenuItem fx:id="saveGame" text="Guardar Partida"  onAction="#handleSaveGame"/>
                        <MenuItem fx:id="loadGame" text="Carregar Partida" onAction="#handleLoadGame"/>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="quitGame" text="Sortir"           onAction="#handleQuitGame"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <!-- CENTRE -->
    <center>
        <HBox spacing="0">

            <!-- TAULER (esquerra) -->
            <VBox style="-fx-background-color: #0a1424; -fx-padding: 15;">
                <Label text="🏔️  Tauler de Joc"
                       style="-fx-text-fill: #90caf9; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>
                <GridPane fx:id="tablero"
                          gridLinesVisible="true"
                          style="-fx-background-color: #0a1a30; -fx-border-color: #1e4a7f; -fx-border-width: 2;">
                    <!-- 5 columnes -->
                    <columnConstraints>
                        <ColumnConstraints minWidth="90" prefWidth="100" maxWidth="110"/>
                        <ColumnConstraints minWidth="90" prefWidth="100" maxWidth="110"/>
                        <ColumnConstraints minWidth="90" prefWidth="100" maxWidth="110"/>
                        <ColumnConstraints minWidth="90" prefWidth="100" maxWidth="110"/>
                        <ColumnConstraints minWidth="90" prefWidth="100" maxWidth="110"/>
                    </columnConstraints>
                    <!-- 10 files -->
                    <rowConstraints>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                        <RowConstraints minHeight="50" prefHeight="55" maxHeight="60"/>
                    </rowConstraints>

                    <!-- Fichas dels jugadors (comencen a row=0, col=0) -->
                    <Circle fx:id="P1" radius="18" fill="#1565c0"
                            GridPane.rowIndex="0" GridPane.columnIndex="0"
                            GridPane.halignment="CENTER" GridPane.valignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, #1565c0, 8, 0.5, 0, 0);"/>
                    <Circle fx:id="P2" radius="18" fill="#c62828"
                            GridPane.rowIndex="0" GridPane.columnIndex="0"
                            GridPane.halignment="CENTER" GridPane.valignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, #c62828, 8, 0.5, 0, 0);
                                   -fx-translate-x: 20;"/>
                    <Circle fx:id="P3" radius="18" fill="#2e7d32"
                            GridPane.rowIndex="0" GridPane.columnIndex="0"
                            GridPane.halignment="CENTER" GridPane.valignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, #2e7d32, 8, 0.5, 0, 0);
                                   -fx-translate-y: 20;"/>
                    <Circle fx:id="P4" radius="18" fill="#f9a825"
                            GridPane.rowIndex="0" GridPane.columnIndex="0"
                            GridPane.halignment="CENTER" GridPane.valignment="CENTER"
                            style="-fx-effect: dropshadow(gaussian, #f9a825, 8, 0.5, 0, 0);
                                   -fx-translate-x: 20; -fx-translate-y: 20;"/>
                </GridPane>
            </VBox>

            <!-- PANEL LATERAL DRET -->
            <VBox spacing="14" minWidth="250" maxWidth="280"
                  style="-fx-background-color: #0c1a32; -fx-padding: 18; -fx-border-color: #1a3a5c; -fx-border-width: 0 0 0 2;">

                <!-- Resultat del dau -->
                <VBox spacing="6" style="-fx-background-color: #08152e; -fx-background-radius: 10;
                                          -fx-border-color: #1e4a7f; -fx-border-radius: 10; -fx-padding: 14;">
                    <Label text="🎲  Resultat del dau"
                           style="-fx-text-fill: #90caf9; -fx-font-size: 12; -fx-font-weight: bold;"/>
                    <Text fx:id="dadoResultText" text="—"
                          style="-fx-fill: #e0f4ff; -fx-font-size: 22; -fx-font-weight: bold;"/>
                    <Button fx:id="dado" text="🎲  Tirar el Dau"
                            onAction="#handleDado"
                            maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color: linear-gradient(to right, #b71c1c, #e53935);
                                   -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;
                                   -fx-background-radius: 20; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, #b71c1c, 10, 0.4, 0, 3);"/>
                </VBox>

                <!-- Inventari d'ítems -->
                <VBox spacing="8" style="-fx-background-color: #08152e; -fx-background-radius: 10;
                                          -fx-border-color: #1e4a7f; -fx-border-radius: 10; -fx-padding: 14;">
                    <Label text="🎒  Inventari"
                           style="-fx-text-fill: #90caf9; -fx-font-size: 12; -fx-font-weight: bold;"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text fx:id="rapido_t" text="×0" style="-fx-fill: #80cbc4; -fx-font-size: 13;"/>
                        <Button fx:id="rapido" text="🏎️ Dau Ràpid" onAction="#handleRapido"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="32"
                                style="-fx-background-color: #0d3a2a; -fx-text-fill: #80cbc4;
                                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text fx:id="lento_t" text="×0" style="-fx-fill: #ce93d8; -fx-font-size: 13;"/>
                        <Button fx:id="lento" text="🐢 Dau Lent" onAction="#handleLento"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="32"
                                style="-fx-background-color: #2a0d3a; -fx-text-fill: #ce93d8;
                                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text fx:id="peces_t" text="×0" style="-fx-fill: #4fc3f7; -fx-font-size: 13;"/>
                        <Button fx:id="peces" text="🐟 Peixos" onAction="#handlePeces"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="32"
                                style="-fx-background-color: #0a2a3a; -fx-text-fill: #4fc3f7;
                                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text fx:id="nieve_t" text="×0" style="-fx-fill: #e0f4ff; -fx-font-size: 13;"/>
                        <Button fx:id="nieve" text="❄️ Boles de Neu" onAction="#handleNieve"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="32"
                                style="-fx-background-color: #0a1e3a; -fx-text-fill: #e0f4ff;
                                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <!-- Esdeveniments -->
                <VBox spacing="6" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #08152e; -fx-background-radius: 10;
                              -fx-border-color: #1e4a7f; -fx-border-radius: 10; -fx-padding: 14;">
                    <Label text="📋  Esdeveniments"
                           style="-fx-text-fill: #90caf9; -fx-font-size: 12; -fx-font-weight: bold;"/>
                    <Text fx:id="eventos" text="El joc ha començat!"
                          wrappingWidth="210"
                          style="-fx-fill: #b0bec5; -fx-font-size: 12;"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
