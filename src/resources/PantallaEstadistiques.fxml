<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaEstadistiques"
           prefWidth="1280" prefHeight="720"
           stylesheets="@PantallaMenu.css">

    <VBox alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" spacing="30" maxWidth="1100" styleClass="glass-card" style="-fx-padding: 40; -fx-background-radius: 40;">
            
            <VBox alignment="CENTER" spacing="5">
                <Label text="📊 ESTADÍSTIQUES I RANKINGS" styleClass="title" 
                       style="-fx-font-size: 54px; -fx-text-fill: linear-gradient(to bottom, #ffffff, #00BFFF);"/>
                <Label text="Arctic Edition - Històric de Jugadors" styleClass="subtitle"/>
            </VBox>

            <HBox spacing="25" alignment="CENTER">
                <VBox spacing="8" alignment="CENTER" styleClass="ice-card" style="-fx-min-width: 220; -fx-background-color: rgba(0, 191, 255, 0.15);">
                    <Label text="🏆 MITJA VICTÒRIES" style="-fx-text-fill: #e0f0ff; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label fx:id="lblMitjaGlobal" text="0.0" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, #00BFFF, 10, 0, 0, 0);"/>
                </VBox>
                <VBox spacing="8" alignment="CENTER" styleClass="ice-card" style="-fx-min-width: 220; -fx-background-color: rgba(255, 215, 0, 0.15);">
                    <Label text="👑 RÈCORD VICTÒRIES" style="-fx-text-fill: #e0f0ff; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label fx:id="lblRecordGlobal" text="0" style="-fx-text-fill: #FFD700; -fx-font-size: 32px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, #FFD700, 10, 0, 0, 0);"/>
                </VBox>
                <VBox spacing="8" alignment="CENTER" styleClass="ice-card" style="-fx-min-width: 220; -fx-background-color: rgba(0, 255, 0, 0.15);">
                    <Label text="👤 LES TEVES VICTÒRIES" style="-fx-text-fill: #e0f0ff; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label fx:id="lblVictoriesPropies" text="0" style="-fx-text-fill: #00FF00; -fx-font-size: 32px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, #00FF00, 10, 0, 0, 0);"/>
                </VBox>
            </HBox>

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <Tab text="📈 Partides Totals">
                    <TableView fx:id="tblRankingPartides" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colNomPartides" text="Jugador" prefWidth="450"/>
                            <TableColumn fx:id="colTotalPartides" text="Total Partides Jugades" prefWidth="250"/>
                        </columns>
                    </TableView>
                </Tab>
                <Tab text="🥇 Campions (Rècord)">
                    <TableView fx:id="tblRankingRecord" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colNomRecord" text="Jugador" prefWidth="450"/>
                            <TableColumn fx:id="colMaxVics" text="Victòries" prefWidth="250"/>
                        </columns>
                    </TableView>
                </Tab>
                <Tab text="🔝 Superior a la Mitja">
                    <TableView fx:id="tblRankingSobreMitja" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colNomSobreMitja" text="Jugador" prefWidth="450"/>
                            <TableColumn fx:id="colVicsSobreMitja" text="Victòries" prefWidth="250"/>
                        </columns>
                    </TableView>
                </Tab>
                <Tab text="🧮 Percentatges">
                    <VBox spacing="25" alignment="CENTER" style="-fx-padding: 40; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20;">
                        <Label text="Introdueix un nº de victòries per saber quin % de jugadors tenen MENYS victòries:" 
                               style="-fx-text-fill: #b3d4ff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <HBox spacing="15" alignment="CENTER">
                            <TextField fx:id="txtPuntuacio" promptText="Ex: 5" prefWidth="150" 
                                       style="-fx-background-color: rgba(0,0,0,0.5); -fx-text-fill: white; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;"/>
                            <Button text="CALCULAR" onAction="#handleCalcularPercentatge" styleClass="button-primary"/>
                        </HBox>
                        <Label fx:id="lblResultatPercentatge" text="" style="-fx-text-fill: #00FF00; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                </Tab>
                <Tab text="🔍 Consultar Jugador">
                    <VBox spacing="25" alignment="CENTER" style="-fx-padding: 40; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20;">
                        <Label text="Introdueix el nom d'un jugador per veure la seva posició al rànquing:" 
                               style="-fx-text-fill: #b3d4ff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <HBox spacing="15" alignment="CENTER">
                            <TextField fx:id="txtNomJugador" promptText="Nom del jugador..." prefWidth="250" 
                                       style="-fx-background-color: rgba(0,0,0,0.5); -fx-text-fill: white; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;"/>
                            <Button text="CONSULTAR" onAction="#handleConsultarJugador" styleClass="button-primary"/>
                        </HBox>
                        <VBox fx:id="containerResultatConsulta" spacing="20" alignment="CENTER" visible="false"
                              style="-fx-background-color: rgba(0, 191, 255, 0.1); -fx-background-radius: 20; -fx-padding: 25; -fx-border-color: rgba(0, 191, 255, 0.3); -fx-border-radius: 20; -fx-border-width: 1;">
                            
                            <HBox spacing="30" alignment="CENTER">
                                <VBox alignment="CENTER" spacing="5">
                                    <Label text="👤 JUGADOR" style="-fx-text-fill: #b3d4ff; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                    <Label fx:id="lblNomResultat" text="---" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;"/>
                                <VBox alignment="CENTER" spacing="5">
                                    <Label text="🏆 VICTÒRIES" style="-fx-text-fill: #b3d4ff; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                    <Label fx:id="lblVicsResultat" text="0" style="-fx-text-fill: #00FF00; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;"/>
                                <VBox alignment="CENTER" spacing="5">
                                    <Label text="🎮 PARTIDES" style="-fx-text-fill: #b3d4ff; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                    <Label fx:id="lblPartResultat" text="0" style="-fx-text-fill: #00BFFF; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;"/>
                                <VBox alignment="CENTER" spacing="5">
                                    <Label text="📍 RÀNQUING" style="-fx-text-fill: #b3d4ff; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                                    <Label fx:id="lblRankResultat" text="#-" style="-fx-text-fill: #FFD700; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <Label fx:id="lblErrorConsulta" text="" style="-fx-text-fill: #ff4b2b; -fx-font-size: 16px; -fx-font-weight: bold;" visible="false"/>
                    </VBox>
                </Tab>
            </TabPane>

            <Button text="← TORNAR AL MENÚ PRINCIPAL" onAction="#handleTornar" styleClass="button-user" 
                    style="-fx-background-color: linear-gradient(to right, #ff4b2b, #ff416c); -fx-font-size: 18px; -fx-padding: 12 40;"/>
        </VBox>
    </VBox>

</StackPane>
