<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Polygon?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>

<StackPane fx:id="root" styleClass="roulette-overlay" 
           xmlns="http://javafx.com/javafx/21" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="vista.PantallaRuleta">
    
    <VBox alignment="CENTER" spacing="30" styleClass="roulette-container">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <StackPane>
            <!-- CAPA 2: La Ruleta que Gira (Con superposición de texto para corregir los 4 premios) -->
            <Group fx:id="wheelGroup">
                <children>
                    <StackPane>
                        <ImageView fx:id="wheelImage" fitWidth="500.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@ruleta.png" />
                            </image>
                        </ImageView>

                        <!-- SOBREESCRITURA DE TEXTOS (Exactamente como en la captura) -->
                        <!-- Norte (0°) -->
                        
                    </StackPane>
                </children>
                <clip>
                     <Circle centerX="250" centerY="250" radius="248" />
                </clip>
            </Group>

            <!-- CAPA 3: Puntero Estático -->
            <Polygon fill="#ffcc00" points="-20.0, 0.0, 20.0, 0.0, 0.0, 35.0" StackPane.alignment="TOP_CENTER">
                <StackPane.margin>
                    <Insets top="5" />
                </StackPane.margin>
                <effect>
                    <DropShadow color="BLACK" radius="8" />
                </effect>
            </Polygon>
        </StackPane>

        <Label fx:id="resultLabel" styleClass="roulette-result" text="DÓNA-LI A GIRAR!" />

        <Button fx:id="spinButton" onAction="#handleGirar" styleClass="spin-button" text="GIRA LA RULETA!" />
        
        <Button fx:id="closeButton" onAction="#handleClose" styleClass="button-secondary" text="Tancar" visible="false" />
    </VBox>
</StackPane>
