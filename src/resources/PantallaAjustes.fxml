<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaAjustes"
           stylesheets="/resources/PantallaMenu.css"
           style="-fx-background-color: transparent;">

    <VBox fx:id="rootContainer" alignment="CENTER" maxWidth="450" maxHeight="550" 
          style="-fx-background-color: linear-gradient(to bottom right, #001a33, #050f23); -fx-background-radius: 30; -fx-border-color: #00c6ff; -fx-border-radius: 30; -fx-border-width: 2; -fx-padding: 30;" 
          spacing="20">
        
        <Label text="AJUSTES" styleClass="title" style="-fx-font-size: 32px; -fx-text-fill: white;"/>

        <VBox spacing="20">
            <!-- Música -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="MÚSICA" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblMusica" text="80%" style="-fx-text-fill: #00d2ff; -fx-font-weight: bold;" />
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Slider fx:id="sldMusica" value="80" max="100" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnMuteMusica" text="🔊" onAction="#handleMuteMusica" 
                            style="-fx-background-color: linear-gradient(to right, #00c6ff, #0072ff); -fx-background-radius: 10; -fx-text-fill: white; -fx-min-width: 45; -fx-font-size: 14px; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Sons Especials -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="SONS ESPECIALS" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblEfectes" text="100%" style="-fx-text-fill: #00d2ff; -fx-font-weight: bold;" />
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Slider fx:id="sldEfectes" value="100" max="100" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnMuteEfectes" text="🔊" onAction="#handleMuteEfectes" 
                            style="-fx-background-color: linear-gradient(to right, #00c6ff, #0072ff); -fx-background-radius: 10; -fx-text-fill: white; -fx-min-width: 45; -fx-font-size: 14px; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Ajuda -->
            <VBox spacing="10" alignment="CENTER">
                <Label text="NECESSITES AJUDA?" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <Button fx:id="btnGuia" text="GUIA DEL JOC" 
                        style="-fx-background-color: rgba(0,200,255,0.2); -fx-border-color: #00c6ff; -fx-border-radius: 15; -fx-background-radius: 15; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 200; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </VBox>
        </VBox>

        <HBox alignment="CENTER" spacing="20">
            <Button text="CANCEL·LAR" onAction="#handleCancelar" 
                    style="-fx-background-color: #334466; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120; -fx-padding: 10 20; -fx-cursor: hand;"/>
            <Button text="GUARDAR" onAction="#handleGuardar" 
                    style="-fx-background-color: linear-gradient(to right, #00c6ff, #0072ff); -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0, 114, 255, 0.5), 10, 0, 0, 4);"/>
        </HBox>

    </VBox>

</StackPane>
