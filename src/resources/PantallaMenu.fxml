<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaMenu"
           prefWidth="1280" prefHeight="720"
           stylesheets="@PantallaMenu.css">


    <!-- CAPA DE CONTENIDO -->
    <BorderPane>
        <top>
            <MenuBar styleClass="menu-bar">
                <menus>
                    <Menu text="Joc del Pingüí">
                        <items>
                            <MenuItem fx:id="newGame"  text="❄️ Nova Partida"     onAction="#handleNewGame"/>
                            <MenuItem fx:id="saveGame" text="💾 Guardar Partida"  onAction="#handleSaveGame"/>
                            <MenuItem fx:id="loadGame" text="📂 Carregar Partida" onAction="#handleLoadGame"/>
                            <SeparatorMenuItem/>
                            <MenuItem fx:id="quitGame" text="🚪 Sortir"           onAction="#handleQuitGame"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="20">
                
                <!-- TÍTULOS -->
                <VBox alignment="CENTER" spacing="0">
                    <Label text="JOC DEL PINGÜÍ" styleClass="title"/>
                    <Label text="L'aventura gelada t'espera" styleClass="subtitle"/>
                </VBox>

                <!-- CARD DE LOGIN -->
                <VBox spacing="20" styleClass="glass-card" alignment="CENTER" maxWidth="420">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40"/>
                    </padding>

                    <Label text="PERFIL DEL JUGADOR" styleClass="card-title"/>

                    <VBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="USUARI" styleClass="field-label"/>
                        <HBox styleClass="input-container" alignment="CENTER_LEFT">
                            <TextField fx:id="userField" promptText="Introdueix el teu nom" HBox.hgrow="ALWAYS" styleClass="styled-input"/>
                            <Label text="🐧" styleClass="input-icon"/>
                        </HBox>
                    </VBox>
                    
                    <VBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="CONTRASENYA" styleClass="field-label"/>
                        <HBox styleClass="input-container" alignment="CENTER_LEFT">
                            <PasswordField fx:id="passField" promptText="••••••••" HBox.hgrow="ALWAYS" styleClass="styled-input"/>
                            <Label text="🔒" styleClass="input-icon"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="15" alignment="CENTER">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                        <Button fx:id="loginButton" text="🎮 ENTRAR AL JOC" onAction="#handleLogin"
                                maxWidth="Infinity" styleClass="button-primary"/>
                        <Button fx:id="registerButton" text="📝 Crear Nou Compte" onAction="#handleRegister"
                                maxWidth="Infinity" styleClass="button-secondary"/>
                    </VBox>
                </VBox>

                <Label text="© 2026 Joc del Pingüí - DW2526 · Grup 03" styleClass="footer-text"/>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
