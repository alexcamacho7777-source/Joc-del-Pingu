<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaMenu"
           prefWidth="1280" prefHeight="720"
           stylesheets="@PantallaMenu.css">

    <!-- CONTINGUT CENTRAL -->
    <VBox alignment="CENTER" spacing="0">

        <!-- CAPÇALERA: Icona usuari dreta -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20 30 0 30;">
            <Button fx:id="btnUsuari" text="Usuari" onAction="#handleUsuari"
                    styleClass="button-user"/>
        </HBox>

        <!-- BLOC CENTRAL: Títol + subtítol + botons -->
        <VBox alignment="CENTER" spacing="40" VBox.vgrow="ALWAYS">

            <!-- Títol -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="JOC DEL PINGUÍ" styleClass="title"/>
                <Label text="L'aventura gelada t'espera" styleClass="subtitle"/>
            </VBox>

            <!-- Botons principals -->
            <VBox alignment="CENTER" spacing="16" maxWidth="320">
                <Button fx:id="btnJugar" text="JUGAR" onAction="#handleJugar"
                        maxWidth="Infinity" styleClass="button-primary" style="-fx-font-size: 22px; -fx-padding: 20 50;"/>
            </VBox>

            <!-- Usuari loguejat (visible quan hi ha sessió) -->
            <Label fx:id="lblSessio" text="" styleClass="footer-text"
                   style="-fx-font-size: 14px; -fx-text-fill: #80d8ff;"/>
        </VBox>

        <!-- PEU -->
        <Label text="© 2026 Joc del Pingui - DW2526 · Grup 03" styleClass="footer-text"
               style="-fx-padding: 0 0 20 0;"/>
    </VBox>

</StackPane>
