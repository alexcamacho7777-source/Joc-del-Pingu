<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.Reflection?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="vista.PantallaMenu"
            prefWidth="800" prefHeight="600"
            stylesheets="@PantallaMenu.css">



    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="35" maxWidth="400">
                
                <!-- TÍTULO ANIMADO -->
                <VBox alignment="CENTER" spacing="0">
                    <Label text="🐧" style="-fx-font-size: 90px;">
                        <effect><Reflection fraction="0.5" topOffset="-5.0" /></effect>
                    </Label>
                    <Label text="JOC DEL PINGÜÍ" styleClass="title"/>
                    <Label text="L'aventura gelada t'espera" styleClass="subtitle"/>
                </VBox>

                <!-- CARD DE LOGIN -->
                <VBox spacing="20" styleClass="glass-card">
                    <VBox spacing="5">
                        <Label text="USUARI" styleClass="field-label"/>
                        <TextField fx:id="userField" promptText="Introdueix el teu nom" styleClass="text-field"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="CONTRASENYA" styleClass="field-label"/>
                        <PasswordField fx:id="passField" promptText="••••••••" styleClass="password-field"/>
                    </VBox>

                    <VBox spacing="15">
                        <VBox.margin>
                            <Insets top="15"/>
                        </VBox.margin>
                        <Button fx:id="loginButton" text="🎮 ENTRAR AL JOC" onAction="#handleLogin"
                                maxWidth="Infinity" styleClass="button-primary"/>
                        <Button fx:id="registerButton" text="📝 Crear Nou Compte" onAction="#handleRegister"
                                maxWidth="Infinity" styleClass="button-secondary"/>
                    </VBox>
                </VBox>

                <Label text="© 2026 Joc del Pingüí - DW2526 · Grup 03" styleClass="footer-text"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
