<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaCrearPartida"
           prefWidth="1280" prefHeight="720"
           stylesheets="@PantallaMenu.css">

    <VBox alignment="CENTER" spacing="30" maxWidth="1000">
        <padding>
            <Insets top="40" bottom="40" left="40" right="40"/>
        </padding>

        <Label text="CONFIGURAR NOVA PARTIDA" styleClass="title" style="-fx-font-size: 54px;"/>

        <VBox spacing="10" styleClass="glass-card" style="-fx-padding: 25;">
            <Label text="NOM DE LA PARTIDA" styleClass="field-label" style="-fx-font-size: 16px;"/>
            <HBox styleClass="input-container">
                <TextField fx:id="txtNomPartida" promptText="Introdueix el nom de la partida..." 
                           styleClass="styled-input" HBox.hgrow="ALWAYS" style="-fx-font-size: 18px;"/>
            </HBox>
        </VBox>

        <VBox spacing="15" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="JUGADORS" styleClass="title" style="-fx-font-size: 32px;"/>
                <Button fx:id="btnAddPlayer" text="+" onAction="#handleAddPlayer" 
                        styleClass="button-primary" style="-fx-font-size: 24px; -fx-padding: 5 20; -fx-background-radius: 50;"/>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="flowJugadores" hgap="20" vgap="20" alignment="TOP_CENTER" style="-fx-padding: 10;">
                    <!-- Player cards will be added here dynamically -->
                </FlowPane>
            </ScrollPane>
        </VBox>

        <HBox alignment="CENTER" spacing="30">
            <Button text="CANCEL·LAR" onAction="#handleTornar" styleClass="button-secondary" style="-fx-font-size: 18px;"/>
            <Button text="COMENÇAR PARTIDA" onAction="#handleComencar" styleClass="button-primary" style="-fx-font-size: 22px;"/>
        </HBox>
    </VBox>
</StackPane>
