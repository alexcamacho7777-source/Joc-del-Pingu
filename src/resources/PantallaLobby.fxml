<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.10"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="vista.PantallaLobby"
            prefWidth="800" prefHeight="600"
            stylesheets="@PantallaMenu.css"
            styleClass="root">

    <!-- Reutilizamos PantallaMenu.css porque tiene los estilos bonitos de fondo y botones -->

    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="40" maxWidth="500">
                
                <VBox alignment="CENTER" spacing="10">
                    <Label text="🧊" style="-fx-font-size: 70px;">
                        <effect><Reflection fraction="0.5" topOffset="-5.0" /></effect>
                    </Label>
                    <Label text="MENÚ PRINCIPAL" styleClass="title"/>
                    <Text fx:id="welcomeText" text="Benvingut, Jugador!" fill="#a0c4e4" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Botones de Acción -->
                <VBox spacing="20" styleClass="glass-card">
                    
                    <HBox alignment="CENTER" spacing="20">
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="👥 HUMANS" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                            <ChoiceBox fx:id="choiceHumans" prefWidth="100"/>
                        </VBox>
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="🤖 IA" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                            <ChoiceBox fx:id="choiceIA" prefWidth="100"/>
                        </VBox>
                    </HBox>

                    <Button fx:id="btnNuevaPartida" text="⚔️ CREAR NOVA PARTIDA" onAction="#handleNuevaPartida"
                            maxWidth="Infinity" styleClass="button-primary" style="-fx-font-size: 18px; -fx-padding: 15;"/>
                    
                    <HBox alignment="CENTER" spacing="10">
                        <Label text="📂 PARTIDA:" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <ChoiceBox fx:id="choicePartidas" prefWidth="120"/>
                        <Button fx:id="btnCargarPartida" text="CARREGAR" onAction="#handleCargarPartida"
                                styleClass="button-primary" style="-fx-font-size: 14px;"/>
                    </HBox>
                            
                    <Separator style="-fx-background-color: transparent; -fx-padding: 10 0;"/>
                    
                    <Button fx:id="btnCerrarSesion" text="🚪 Tancar Sessió" onAction="#handleCerrarSesion"
                            maxWidth="Infinity" styleClass="button-secondary"/>
                </VBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>
