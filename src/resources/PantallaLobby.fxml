<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.cell.MapValueFactory?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="vista.PantallaLobby"
           prefWidth="1280" prefHeight="720"
           stylesheets="@PantallaMenu.css">

    <VBox alignment="CENTER" spacing="20">
        <!-- Top bar with Back button -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 30 0 30;">
            <Button text="Tornar al Menú" onAction="#handleTornar" 
                    styleClass="button-primary" style="-fx-font-size: 18px; -fx-padding: 10 25;"/>
        </HBox>

        <VBox alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS" maxWidth="1100">
            <Label text="PARTIDES GUARDADES" styleClass="title" style="-fx-font-size: 48px;"/>
            <Text fx:id="welcomeText" text="" fill="#a0c4e4" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <!-- Create new game settings -->
            <HBox alignment="CENTER" spacing="20" styleClass="glass-card" style="-fx-padding: 15;">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="HUMANS" styleClass="field-label"/>
                    <ChoiceBox fx:id="choiceHumans" prefWidth="80" styleClass="input-container"/>
                </VBox>
                <VBox alignment="CENTER" spacing="5">
                    <Label text="IA" styleClass="field-label"/>
                    <ChoiceBox fx:id="choiceIA" prefWidth="80" styleClass="input-container"/>
                </VBox>
                <Button text="CREAR NOVA PARTIDA" onAction="#handleNuevaPartida" styleClass="button-primary"/>
            </HBox>

            <!-- Table of existing games wrapped in an ice-card -->
            <VBox styleClass="ice-card" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaPartidas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colNom" text="Nom Partida" prefWidth="150" />
                        <TableColumn fx:id="colData" text="Data Creació" prefWidth="120" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colJugadors" text="Jugadors" prefWidth="450" />
                        <TableColumn fx:id="colTorn" text="Torn" prefWidth="80" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colFinalitzada" text="Finalitzada" prefWidth="100" style="-fx-alignment: CENTER;" />
                    </columns>
                </TableView>
            </VBox>

            <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10 0 0 0;">
                <Button fx:id="btnCargarPartida" text="CARREGAR PARTIDA SELECCIONADA" onAction="#handleCargarPartida" 
                        styleClass="button-primary" style="-fx-font-size: 18px; -fx-padding: 12 30;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
