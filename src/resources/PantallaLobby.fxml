<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.10"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="vista.PantallaLobby"
            prefWidth="1280" prefHeight="720"
            stylesheets="@PantallaMenu.css"
            styleClass="root">

    <center>
        <StackPane>
            <!-- REUSE PREVIOUS BG IF NEEDED VIA CSS OR ADD IMAGEVIEW -->
            <VBox alignment="CENTER" spacing="40" maxWidth="600">
                <padding><Insets top="50" bottom="50"/></padding>
                
                <VBox alignment="CENTER" spacing="10">
                    <Label text="🏔️" style="-fx-font-size: 80px; -fx-effect: dropshadow(gaussian, #00d2ff, 15, 0.5, 0, 0);"/>
                    <Label text="CONFIGURACIÓ DE PARTIDA" styleClass="title" style="-fx-font-size: 48px;"/>
                    <Text fx:id="welcomeText" text="Benvingut, Jugador!" fill="#a0c4e4" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="25" styleClass="glass-card" alignment="CENTER">
                    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
                    
                    <Label text="SELECCIÓ DE JUGADORS" styleClass="card-title"/>
                    
                    <HBox alignment="CENTER" spacing="40">
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="👥 JUGADORS HUMANS" styleClass="field-label"/>
                            <ChoiceBox fx:id="choiceHumans" prefWidth="120" styleClass="input-container"/>
                        </VBox>
                        <VBox spacing="10" alignment="CENTER">
                            <Label text="🤖 ADVERSARIS IA" styleClass="field-label"/>
                            <ChoiceBox fx:id="choiceIA" prefWidth="120" styleClass="input-container"/>
                        </VBox>
                    </HBox>

                    <Separator opacity="0.1" maxWidth="300"/>

                    <Button fx:id="btnNuevaPartida" text="⚔️ COMENÇAR AVENTURA" onAction="#handleNuevaPartida"
                            maxWidth="Infinity" styleClass="button-primary"/>
                    
                    <VBox spacing="10" alignment="CENTER">
                        <Label text="📂 O CARREGAR PARTIDA EXISTENT" styleClass="field-label"/>
                        <HBox alignment="CENTER" spacing="15">
                            <ChoiceBox fx:id="choicePartidas" prefWidth="180" styleClass="input-container"/>
                            <Button fx:id="btnCargarPartida" text="CARREGAR" onAction="#handleCargarPartida"
                                    styleClass="button-secondary"/>
                        </HBox>
                    </VBox>
                            
                    <Button fx:id="btnCerrarSesion" text="🚪 Tancar Sessió" onAction="#handleCerrarSesion"
                            maxWidth="200" styleClass="button-secondary" style="-fx-border-color: rgba(255, 50, 50, 0.3);"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
